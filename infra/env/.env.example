# ─────────────────────────────────────────────
# ESB Bancario — Variables de entorno
# Copia este archivo como .env y llena los valores
# NUNCA subas .env al repositorio
# ─────────────────────────────────────────────
 
# Entorno: development | staging | production
NODE_ENV=development
PORT=3000
 
# ── Seguridad JWT ────────────────────────────
JWT_PUBLIC_KEY=
JWT_ISSUER=
 
# ── Base de datos ────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=esb_bancario
DB_USER=
DB_PASSWORD=
 
# ── Fraude / ML ──────────────────────────────
FRAUD_ML_API_URL=
FRAUD_ML_API_KEY=
 
# ── OFAC ─────────────────────────────────────
OFAC_SCREENING_URL=
OFAC_API_KEY=
 
# ── Redes externas ───────────────────────────
PROSA_API_URL=
PROSA_API_KEY=
SWIFT_ENDPOINT=
BANXICO_SPEI_URL=
 
# ── Monitoring ───────────────────────────────
MONITORING_PORT=9090
LOG_LEVEL=info

